{
  "models": {
    "primary": "facebook/layerskip-llama2-13B",
    "all_layerskip": [
      "facebook/layerskip-llama2-13B"
    ],
    "vanilla_baseline": "meta-llama/Llama-2-70b-hf"
  },

  "ptq_methods": {
    "fp16": {
      "description": "Standard float16 — no quantization, reference baseline",
      "bits_weights": 16,
      "bits_activations": 16,
      "library": "transformers"
    },
    "int8_bnb": {
      "description": "Naive int8 via bitsandbytes LLM.int8() — simple PTQ baseline",
      "bits_weights": 8,
      "bits_activations": 8,
      "library": "bitsandbytes"
    },
    "awq": {
      "description": "Activation-aware Weight Quantization — W4A16",
      "bits_weights": 4,
      "bits_activations": 16,
      "group_size": 128,
      "library": "llmcompressor"
    },
    "gptq": {
      "description": "GPTQ second-order weight quantization — W4A16",
      "bits_weights": 4,
      "bits_activations": 16,
      "group_size": 128,
      "library": "llmcompressor"
    },
    "smoothquant": {
      "description": "SmoothQuant migration of quantization difficulty — W8A8",
      "bits_weights": 8,
      "bits_activations": 8,
      "alpha": 0.5,
      "library": "smoothquant",
      "repo": "https://github.com/mit-han-lab/smoothquant"
    }
  },

  "decoding_strategies": {
    "autoregressive": {
      "generation_strategy": "autoregressive"
    },
    "self_speculative_small": {
      "generation_strategy": "self_speculative",
      "exit_layer": 20,
      "num_speculations": 6
    },
    "self_speculative_medium": {
      "generation_strategy": "self_speculative",
      "exit_layer": 30,
      "num_speculations": 6
    },
    "self_speculative_large": {
      "generation_strategy": "self_speculative",
      "exit_layer": 40,
      "num_speculations": 6
    }
  },

  "tasks": {
    "cnn_dm_summarization": {
      "dataset": "cnn_dm_summarization",
      "num_samples": 100,
      "primary_metric": "rouge_l",
      "type": "generation"
    },
    "xsum_summarization": {
      "dataset": "xsum_summarization",
      "num_samples": 100,
      "primary_metric": "rouge_l",
      "type": "generation"
    }
  },

  "eval_tasks_lm_harness": {
    "mmlu": { "num_samples": 100, "metric": "accuracy", "type": "classification" },
    "arc_challenge": { "num_samples": 100, "metric": "accuracy", "type": "classification" }
  },

  "layerskip_sweep": {
    "exit_layers": [10, 20, 30, 40],
    "num_speculations": [4, 6, 8],
    "sweep_dataset": "cnn_dm_summarization",
    "sweep_num_samples": 1
  },

  "paths": {
    "layerskip_dir": "./LayerSkip",
    "quantized_models_dir": "./quantized_models",
    "logs_dir": "./logs",
    "results_dir": "./results",
    "figures_dir": "./figures",
    "model_cache_dir": "./model_cache"
  },

  "energy": {
    "gpu_device_idx": 0,
    "sample_interval_s": 0.1
  }
}
